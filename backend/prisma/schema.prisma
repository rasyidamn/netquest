// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ENUMS
enum RoleEnum {
  ADMIN
  MAHASISWA
}

enum LessonTypeEnum {
  THEORY
  QUIZ
}

enum ProgressStatusEnum {
  LOCKED
  ACTIVE
  COMPLETED
}

enum QuestionType {
  MULTIPLE_CHOICE // Pilihan Ganda
  CALCULATION_INPUT // Isian Singkat Kalkulasi
  COMMAND_TYPING // Simulasi CLI / Terminal
  SORTING // Mengurutkan (Drag & Drop)
  MATCHING // Menjodohkan
  TOPOLOGY // Topologi Interaktif Canvas
  RAPID_TRUE_FALSE // Swift Card Benar/Salah
  VISUAL_IDENTIFICATION // Image Select / Hotspot
}

// MODELS
model User {
  id               String   @id @default(uuid()) @db.Uuid
  nim              String   @unique
  name             String
  password         String
  role             RoleEnum @default(MAHASISWA)
  xp               Int      @default(0)
  hearts           Int      @default(3)
  heartsUpdatedAt  DateTime @default(now()) @map("hearts_updated_at")
  recoveryCount    Int      @default(0) @map("recovery_count")
  lastRecoveryDate DateTime @default(now()) @map("last_recovery_date")
  createdAt        DateTime @default(now())

  // relasi
  progress UserProgress[]

  @@map("users")
}

model Module {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  description String?  @db.Text
  sequence    Int      @unique // urutan modul
  isPublished Boolean  @default(false) @map("is_published")

  // relasi
  lessons Lesson[]

  @@map("modules")
}

model Lesson {
  id             String         @id @default(uuid()) @db.Uuid
  moduleId       String         @map("module_id") @db.Uuid
  title          String
  lessonSequence Int            @map("lesson_sequence")
  type           LessonTypeEnum
  xpReward       Int            @map("xp_reward")
  isPublished    Boolean        @default(false) @map("is_published")

  // relasi
  module       Module         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  material     Material?
  questions    Question[]
  userProgress UserProgress[]

  @@unique([moduleId, lessonSequence])
  @@map("lessons")
}

model Material {
  id       String  @id @default(uuid()) @db.Uuid
  lessonId String  @unique @map("lesson_id") @db.Uuid
  content  String  @db.Text
  mediaUrl String? @map("media_url")

  // relasi 
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("materials")
}

model Question {
  id           String       @id @default(uuid()) @db.Uuid
  lessonId     String       @map("lesson_id") @db.Uuid
  questionText String       @map("question_text") @db.Text
  xpReward     Int          @default(15) @map("xp_reward")
  type         QuestionType @default(MULTIPLE_CHOICE)

  // relasi
  lesson  Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  options Option[]

  @@map("questions")
}

model Option {
  id         String  @id @default(uuid()) @db.Uuid
  questionId String  @map("question_id") @db.Uuid
  optionText String  @map("option_text")
  isCorrect  Boolean @map("is_correct")

  // relasi
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("options")
}

model UserProgress {
  id        String             @id @default(uuid()) @db.Uuid
  userId    String             @map("user_id") @db.Uuid
  lessonId  String             @map("lesson_id") @db.Uuid // GANTI moduleId menjadi lessonId
  status    ProgressStatusEnum @default(LOCKED)
  bestScore Int                @default(0) @map("best_score")
  createdAt DateTime           @default(now()) @map("created_at")

  // relation
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  // MENCEGAH DUPLIKASI DATA: 1 Mahasiswa hanya punya 1 record per materi/kuis
  @@unique([userId, lessonId])
  @@map("user_progress")
}
